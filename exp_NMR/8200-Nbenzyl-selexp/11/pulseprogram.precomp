# 48 "/root/.topspin-BladeEpu/local_acqu/ppDirs/seldigpzs"
  
# 52 "/root/.topspin-BladeEpu/local_acqu/ppDirs/seldigpzs"
  4u  


  d1 pl1:f1
  50u setrtp0|0 ctrlgrad 0
  (p1 ph1):f1
  3u
  p16:gp1
  d16
  p12:sp2:f1 ph2:r
  3u
  p16:gp1
  d16 pl1:f1
# 66 "/root/.topspin-BladeEpu/local_acqu/ppDirs/seldigpzs"
  p1 ph3
  10u gron0
  (p32:sp29 ph3):f1
  20u groff
  d16 pl10:f1


						;begin DIPSI2
4 p6*3.556 ph23
  p6*4.556 ph25
  p6*3.222 ph23
  p6*3.167 ph25
  p6*0.333 ph23
  p6*2.722 ph25
  p6*4.167 ph23
  p6*2.944 ph25
  p6*4.111 ph23
  
  p6*3.556 ph25
  p6*4.556 ph23
  p6*3.222 ph25
  p6*3.167 ph23
  p6*0.333 ph25
  p6*2.722 ph23
  p6*4.167 ph25
  p6*2.944 ph23
  p6*4.111 ph25
