  p1 ph3
  
  go=2 ph31
# 1 "mc_line 133 file /root/.topspin-BladeEpu/local_acqu/ppDirs/seldigpzs exp. mc cmd. in line"
  MCWRK wr #0
  MCWRK zd
  lo to LBLF0 times td0

